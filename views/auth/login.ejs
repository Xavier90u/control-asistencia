<% layout = 'layouts/main'; titulo = 'Iniciar Sesión'; %>
<div class="min-h-[85vh] flex items-center justify-center px-4 py-8">
  <div class="card-surface p-6 sm:p-8 rounded-2xl shadow-xl w-full max-w-md border">
    <div class="text-center mb-8">
      <div class="w-20 h-20 mx-auto mb-4 rounded-2xl flex items-center justify-center text-4xl" style="background-color: var(--color-primary-light);">⏰</div>
      <h1 class="text-2xl font-bold text-primary">Control de Asistencia</h1>
      <p class="text-muted text-sm mt-2">Ingresa tus credenciales para continuar</p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 border border-red-200 text-red-600 p-3 mb-5 rounded-xl text-sm flex items-center gap-2">
      <span>⚠️</span> <%= error %>
    </div>
    <% } %>
    <form action="/login" method="POST" class="space-y-5">
      <div>
        <label class="block text-sm font-semibold mb-2" for="email" style="color: var(--color-muted);">Correo electrónico</label>
        <input type="email" name="email" id="email" required
          class="w-full px-4 py-3 border-2 rounded-xl focus:ring-2 outline-none transition text-base"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);"
          placeholder="correo@ejemplo.com">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-2" for="password" style="color: var(--color-muted);">Contraseña</label>
        <input type="password" name="password" id="password" required
          class="w-full px-4 py-3 border-2 rounded-xl focus:ring-2 outline-none transition text-base"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);"
          placeholder="••••••••">
      </div>
      <button type="submit" class="btn-primary w-full font-semibold py-3 px-4 rounded-xl transition text-base shadow-lg">
        Ingresar
      </button>
    </form>
  </div>
</div>

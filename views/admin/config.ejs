<% titulo = 'Configuración - Admin'; %>
<h1 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Configuración</h1>

<div class="max-w-lg">
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm">
    <form action="/admin/config" method="POST" class="space-y-5">
      <div>
        <h2 class="text-sm font-bold text-gray-800 dark:text-white border-b border-gray-100 dark:border-gray-800 pb-2 mb-3">🕐 Jornada laboral</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Hora de inicio</label>
            <input type="time" name="hora_inicio_general" value="<%= config.hora_inicio_general || '08:00' %>" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
          </div>
          <div>
            <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Tolerancia (min)</label>
            <input type="number" name="tolerancia_general" min="0" value="<%= config.tolerancia_general || '10' %>" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
          </div>
          <div>
            <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Descuento por min (S/)</label>
            <input type="number" step="0.01" min="0" name="descuento_por_minuto" value="<%= config.descuento_por_minuto || '0.50' %>" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-sm font-bold text-gray-800 dark:text-white border-b border-gray-100 dark:border-gray-800 pb-2 mb-3">🌍 Zona horaria</h2>
        <div class="space-y-3">
          <div>
            <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Zona horaria</label>
            <select name="zona_horaria" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
              <% const zonas = ['America/Lima', 'America/Bogota', 'America/Mexico_City', 'America/Argentina/Buenos_Aires', 'America/Santiago', 'America/Caracas', 'America/La_Paz', 'America/Guayaquil']; %>
              <% zonas.forEach(function(z) { %>
              <option value="<%= z %>" <%= (config.zona_horaria || 'America/Lima') === z ? 'selected' : '' %>><%= z %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Formato fecha</label>
            <select name="formato_fecha" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
              <% ['YYYY-MM-DD', 'DD/MM/YYYY', 'DD-MM-YYYY'].forEach(function(f) { %>
              <option value="<%= f %>" <%= (config.formato_fecha || 'YYYY-MM-DD') === f ? 'selected' : '' %>><%= f %></option>
              <% }); %>
            </select>
          </div>
          <div>
            <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Formato hora</label>
            <select name="formato_hora" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
              <% ['HH:mm:ss', 'HH:mm', 'h:mm A'].forEach(function(f) { %>
              <option value="<%= f %>" <%= (config.formato_hora || 'HH:mm:ss') === f ? 'selected' : '' %>><%= f %></option>
              <% }); %>
            </select>
          </div>
        </div>
      </div>

      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition text-sm">
        Guardar Configuración
      </button>
    </form>
  </div>
</div>

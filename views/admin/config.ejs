<% titulo = 'Configuración - Admin'; %>
<h1 class="text-2xl sm:text-3xl font-bold text-primary mb-6">Configuración General</h1>

<div class="max-w-2xl">
  <div class="card-surface rounded-2xl shadow-lg p-5 sm:p-6 border">
    <form action="/admin/config" method="POST" class="space-y-6">
      <h2 class="text-base font-bold text-primary border-b pb-3 flex items-center gap-2" style="border-color: var(--color-border);">
        <span>🕐</span> Jornada laboral
      </h2>

      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Hora de inicio de jornada</label>
        <input type="time" name="hora_inicio_general" value="<%= config.hora_inicio_general || '08:00' %>"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
        <p class="text-xs text-muted mt-1.5 opacity-60">Hora a partir de la cual se considera tardanza</p>
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Tolerancia (minutos)</label>
        <input type="number" name="tolerancia_general" min="0" value="<%= config.tolerancia_general || '10' %>"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
        <p class="text-xs text-muted mt-1.5 opacity-60">Minutos de gracia antes de contar como tardanza</p>
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Descuento por minuto de retraso (S/)</label>
        <div class="relative">
          <span class="absolute left-4 top-3 font-semibold" style="color: var(--color-muted);">S/</span>
          <input type="number" step="0.01" min="0" name="descuento_por_minuto" value="<%= config.descuento_por_minuto || '0.50' %>"
            class="w-full pl-10 pr-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
            style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
        </div>
        <p class="text-xs text-muted mt-1.5 opacity-60">Monto a descontar por cada minuto de retraso</p>
      </div>

      <h2 class="text-base font-bold text-primary border-b pb-3 flex items-center gap-2" style="border-color: var(--color-border);">
        <span>🌍</span> Zona horaria y formato
      </h2>

      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Zona horaria</label>
        <select name="zona_horaria"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
          <% const zonas = ['America/Lima', 'America/Bogota', 'America/Mexico_City', 'America/Argentina/Buenos_Aires', 'America/Santiago', 'America/Caracas', 'America/La_Paz', 'America/Guayaquil', 'America/Managua', 'America/Guatemala', 'America/Panama', 'America/Havana', 'America/Santo_Domingo', 'America/Asuncion', 'America/Montevideo']; %>
          <% zonas.forEach(function(z) { %>
          <option value="<%= z %>" <%= (config.zona_horaria || 'America/Lima') === z ? 'selected' : '' %>><%= z %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Formato de fecha</label>
        <select name="formato_fecha"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
          <% const formatosFecha = ['YYYY-MM-DD', 'DD/MM/YYYY', 'DD-MM-YYYY', 'MM/DD/YYYY', 'DD.MM.YYYY']; %>
          <% formatosFecha.forEach(function(f) { %>
          <option value="<%= f %>" <%= (config.formato_fecha || 'YYYY-MM-DD') === f ? 'selected' : '' %>><%= f %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Formato de hora</label>
        <select name="formato_hora"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
          <% const formatosHora = ['HH:mm:ss', 'HH:mm', 'h:mm:ss A', 'h:mm A']; %>
          <% formatosHora.forEach(function(f) { %>
          <option value="<%= f %>" <%= (config.formato_hora || 'HH:mm:ss') === f ? 'selected' : '' %>><%= f %></option>
          <% }); %>
        </select>
      </div>

      <div class="pt-2">
        <button type="submit"
          class="btn-primary w-full font-semibold py-3 px-4 rounded-xl transition shadow-lg">
          Guardar Configuración
        </button>
      </div>
    </form>
  </div>
</div>

<% titulo = 'Configuración - Admin'; %>
<h1 class="text-2xl font-bold text-gray-800 mb-6">Configuración General</h1>

<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow-md p-6">
    <form action="/admin/config" method="POST" class="space-y-5">
      <h2 class="text-lg font-semibold text-gray-800 border-b pb-2">Jornada laboral</h2>

      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Hora de inicio de jornada</label>
        <input type="time" name="hora_inicio_general" value="<%= config.hora_inicio_general || '08:00' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        <p class="text-xs text-gray-400 mt-1">Hora a partir de la cual se considera tardanza (después de la tolerancia)</p>
      </div>
      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Tolerancia (minutos)</label>
        <input type="number" name="tolerancia_general" min="0" value="<%= config.tolerancia_general || '10' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        <p class="text-xs text-gray-400 mt-1">Minutos de gracia antes de contar como tardanza</p>
      </div>
      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Descuento por minuto de retraso (S/)</label>
        <div class="relative">
          <span class="absolute left-3 top-2.5 text-gray-500">S/</span>
          <input type="number" step="0.01" min="0" name="descuento_por_minuto" value="<%= config.descuento_por_minuto || '0.50' %>"
            class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        </div>
        <p class="text-xs text-gray-400 mt-1">Monto a descontar por cada minuto de retraso</p>
      </div>

      <h2 class="text-lg font-semibold text-gray-800 border-b pb-2 mt-2">Zona horaria y formato</h2>

      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Zona horaria</label>
        <select name="zona_horaria"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          <% const zonas = ['America/Lima', 'America/Bogota', 'America/Mexico_City', 'America/Argentina/Buenos_Aires', 'America/Santiago', 'America/Caracas', 'America/La_Paz', 'America/Guayaquil', 'America/Managua', 'America/Guatemala', 'America/Panama', 'America/Havana', 'America/Santo_Domingo', 'America/Asuncion', 'America/Montevideo']; %>
          <% zonas.forEach(function(z) { %>
          <option value="<%= z %>" <%= (config.zona_horaria || 'America/Lima') === z ? 'selected' : '' %>><%= z %></option>
          <% }); %>
        </select>
        <p class="text-xs text-gray-400 mt-1">Zona horaria para registrar y mostrar horas</p>
      </div>
      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Formato de fecha</label>
        <select name="formato_fecha"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          <% const formatosFecha = ['YYYY-MM-DD', 'DD/MM/YYYY', 'DD-MM-YYYY', 'MM/DD/YYYY', 'DD.MM.YYYY']; %>
          <% formatosFecha.forEach(function(f) { %>
          <option value="<%= f %>" <%= (config.formato_fecha || 'YYYY-MM-DD') === f ? 'selected' : '' %>><%= f %></option>
          <% }); %>
        </select>
      </div>
      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Formato de hora</label>
        <select name="formato_hora"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
          <% const formatosHora = ['HH:mm:ss', 'HH:mm', 'h:mm:ss A', 'h:mm A']; %>
          <% formatosHora.forEach(function(f) { %>
          <option value="<%= f %>" <%= (config.formato_hora || 'HH:mm:ss') === f ? 'selected' : '' %>><%= f %></option>
          <% }); %>
        </select>
      </div>

      <div class="pt-2">
        <button type="submit"
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-4 rounded-lg transition duration-200">
          Guardar Configuración
        </button>
      </div>
    </form>
  </div>
</div>

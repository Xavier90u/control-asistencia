<% titulo = 'Editar Área - Admin'; %>
<div class="max-w-4xl mx-auto">
  <div class="flex items-center space-x-3 mb-6">
    <a href="/admin/areas" class="text-blue-600 hover:text-blue-800">&larr; Volver</a>
    <h1 class="text-2xl font-bold text-gray-800">Editar Área: <%= area.nombre %></h1>
  </div>

  <div class="bg-white rounded-xl shadow-md p-6">
    <form action="/admin/areas/<%= area._id %>" method="POST" class="space-y-6">
      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Nombre del área</label>
        <input type="text" name="nombre" value="<%= area.nombre %>" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
      </div>

      <p class="text-sm font-medium text-gray-700">Franjas horarias disponibles por día</p>
      <p class="text-xs text-gray-400 mb-2">Marca las horas de entrada disponibles para cada día de la semana.</p>

      <% for (var d = 0; d <= 6; d++) { %>
      <div class="border-b pb-3 mb-3">
        <p class="text-sm font-semibold text-gray-700 mb-2"><%= dias[d] %></p>
        <div class="flex flex-wrap gap-2">
          <% horas.forEach(function(h) { %>
            <% var franjasDia = area.franjasPorDia ? (area.franjasPorDia.get ? area.franjasPorDia.get(String(d)) : area.franjasPorDia[d]) : []; %>
            <% var checked = franjasDia && franjasDia.includes(h); %>
            <label class="flex items-center space-x-1.5 px-3 py-1.5 border rounded-lg cursor-pointer text-sm <%= checked ? 'bg-blue-50 border-blue-300' : 'bg-gray-50 border-gray-200' %>">
              <input type="checkbox" name="franjas[<%= d %>]" value="<%= h %>" <%= checked ? 'checked' : '' %>
                onchange="this.parentElement.className = this.checked ? 'flex items-center space-x-1.5 px-3 py-1.5 border rounded-lg cursor-pointer text-sm bg-blue-50 border-blue-300' : 'flex items-center space-x-1.5 px-3 py-1.5 border rounded-lg cursor-pointer text-sm bg-gray-50 border-gray-200'">
              <span><%= h %></span>
            </label>
          <% }); %>
        </div>
      </div>
      <% } %>

      <div class="flex justify-end space-x-3 pt-2">
        <a href="/admin/areas" class="px-4 py-2 text-gray-600 border border-gray-300 rounded-lg text-sm">Cancelar</a>
        <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

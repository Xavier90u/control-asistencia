<% titulo = 'Dashboard - Admin'; %>
<h1 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h1>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-blue-500">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-500 text-sm font-medium">Total Empleados</p>
        <p class="text-3xl font-bold text-gray-800 mt-1"><%= totalEmpleados %></p>
      </div>
      <div class="text-blue-500 text-4xl">👥</div>
    </div>
  </div>
  <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-green-500">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-500 text-sm font-medium">Asistencias Hoy</p>
        <p class="text-3xl font-bold text-gray-800 mt-1"><%= asistenciasHoy %></p>
      </div>
      <div class="text-green-500 text-4xl">✅</div>
    </div>
  </div>
  <div class="bg-white rounded-xl shadow-md p-6 border-l-4 border-red-500">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-gray-500 text-sm font-medium">Tardanzas Hoy</p>
        <p class="text-3xl font-bold text-gray-800 mt-1"><%= tardanzasHoy %></p>
      </div>
      <div class="text-red-500 text-4xl">⚠️</div>
    </div>
  </div>
</div>

<div class="bg-white rounded-xl shadow-md p-6">
  <h2 class="text-lg font-semibold text-gray-800 mb-4">Configuración General Actual</h2>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-gray-50 p-4 rounded-lg">
      <p class="text-gray-500 text-sm">Hora de inicio</p>
      <p class="text-xl font-bold text-gray-800"><%= config.hora_inicio_general || '08:00' %></p>
    </div>
    <div class="bg-gray-50 p-4 rounded-lg">
      <p class="text-gray-500 text-sm">Tolerancia</p>
      <p class="text-xl font-bold text-gray-800"><%= config.tolerancia_general || '10' %> min</p>
    </div>
    <div class="bg-gray-50 p-4 rounded-lg">
      <p class="text-gray-500 text-sm">Descuento por minuto</p>
      <p class="text-xl font-bold text-gray-800">S/ <%= parseFloat(config.descuento_por_minuto || '0.50').toFixed(2) %></p>
    </div>
  </div>
</div>

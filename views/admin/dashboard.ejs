<% titulo = 'Dashboard - Admin'; %>
<h1 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Dashboard</h1>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-gray-400 dark:text-gray-500 text-[11px] uppercase font-medium">Empleados</p>
      <p class="text-3xl font-bold text-gray-800 dark:text-white mt-1"><%= totalEmpleados %></p>
    </div>
    <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900 rounded-xl flex items-center justify-center text-xl">👥</div>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-gray-400 dark:text-gray-500 text-[11px] uppercase font-medium">Asistencias Hoy</p>
      <p class="text-3xl font-bold text-green-600 dark:text-green-400 mt-1"><%= asistenciasHoy %></p>
    </div>
    <div class="w-12 h-12 bg-green-100 dark:bg-green-900 rounded-xl flex items-center justify-center text-xl">✅</div>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm flex items-center justify-between">
    <div>
      <p class="text-gray-400 dark:text-gray-500 text-[11px] uppercase font-medium">Tardanzas Hoy</p>
      <p class="text-3xl font-bold text-red-600 dark:text-red-400 mt-1"><%= tardanzasHoy %></p>
    </div>
    <div class="w-12 h-12 bg-red-100 dark:bg-red-900 rounded-xl flex items-center justify-center text-xl">⚠️</div>
  </div>
</div>

<div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm">
  <h2 class="text-sm font-bold text-gray-800 dark:text-white mb-3 flex items-center gap-2">
    <span>⚙️</span> Configuración
  </h2>
  <div class="grid grid-cols-3 gap-2">
    <div class="bg-gray-50 dark:bg-gray-800 p-3 rounded-xl text-center">
      <p class="text-gray-400 dark:text-gray-500 text-[11px] uppercase">Inicio</p>
      <p class="text-lg font-bold text-gray-800 dark:text-white mt-0.5"><%= config.hora_inicio_general || '08:00' %></p>
    </div>
    <div class="bg-gray-50 dark:bg-gray-800 p-3 rounded-xl text-center">
      <p class="text-gray-400 dark:text-gray-500 text-[11px] uppercase">Tolerancia</p>
      <p class="text-lg font-bold text-gray-800 dark:text-white mt-0.5"><%= config.tolerancia_general || '10' %> min</p>
    </div>
    <div class="bg-gray-50 dark:bg-gray-800 p-3 rounded-xl text-center">
      <p class="text-gray-400 dark:text-gray-500 text-[11px] uppercase">Dto/min</p>
      <p class="text-lg font-bold text-gray-800 dark:text-white mt-0.5">S/ <%= parseFloat(config.descuento_por_minuto || '0.50').toFixed(2) %></p>
    </div>
  </div>
</div>

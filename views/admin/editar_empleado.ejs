<% titulo = 'Editar Empleado'; %>
<div class="max-w-md mx-auto">
  <div class="flex items-center gap-2 mb-4">
    <a href="/admin/empleados" class="w-9 h-9 bg-gray-100 dark:bg-gray-800 rounded-xl flex items-center justify-center text-gray-500 hover:bg-gray-200 transition font-bold text-sm">&larr;</a>
    <h1 class="text-xl font-bold text-gray-800 dark:text-white">Editar Empleado</h1>
  </div>
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm">
    <form action="/admin/empleados/<%= empleado.id %>/editar" method="POST" class="space-y-3">
      <div>
        <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Nombre</label>
        <input type="text" name="nombre" value="<%= empleado.nombre %>" required class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
      </div>
      <div>
        <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Email</label>
        <input type="email" name="email" value="<%= empleado.email %>" required class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
      </div>
      <div>
        <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Contraseña <span class="font-normal opacity-60">(vacío = no cambiar)</span></label>
        <input type="password" name="password" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
      </div>
      <div>
        <label class="block text-gray-600 dark:text-gray-400 text-xs font-semibold mb-1">Área</label>
        <select name="area" class="w-full px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
          <option value="">Sin área</option>
          <% areas.forEach(function(a) { %>
          <option value="<%= a._id %>" <%= empleado.area && empleado.area.toString() === a._id.toString() ? 'selected' : '' %>><%= a.nombre %></option>
          <% }); %>
        </select>
      </div>
      <div class="grid grid-cols-3 gap-2">
        <div>
          <label class="block text-gray-600 dark:text-gray-400 text-[11px] font-semibold mb-1">Hora</label>
          <input type="time" name="hora_inicio" value="<%= empleado.hora_inicio || '' %>" class="w-full px-2 py-2 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-gray-600 dark:text-gray-400 text-[11px] font-semibold mb-1">Toler.</label>
          <input type="number" name="tolerancia_minutos" min="0" value="<%= empleado.toleranciaMinutos != null ? empleado.toleranciaMinutos : '' %>" class="w-full px-2 py-2 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
        <div>
          <label class="block text-gray-600 dark:text-gray-400 text-[11px] font-semibold mb-1">Dto/min</label>
          <input type="number" step="0.01" min="0" name="descuento_por_minuto" value="<%= empleado.descuentoPorMinuto != null ? empleado.descuentoPorMinuto : '' %>" class="w-full px-2 py-2 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
        </div>
      </div>
      <div class="flex justify-end gap-2 pt-3 border-t border-gray-100 dark:border-gray-800">
        <a href="/admin/empleados" class="px-4 py-2.5 text-gray-500 border border-gray-300 dark:border-gray-700 rounded-xl text-sm transition">Cancelar</a>
        <button type="submit" class="px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-xl text-sm font-semibold transition">Guardar</button>
      </div>
    </form>
  </div>
</div>

<% titulo = 'Editar Empleado'; %>
<div class="max-w-lg mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin/empleados" class="w-10 h-10 rounded-xl flex items-center justify-center transition font-bold" style="background-color: var(--color-surface-alt); color: var(--color-muted);">&larr;</a>
    <h1 class="text-2xl sm:text-3xl font-bold text-primary">Editar Empleado</h1>
  </div>
  <div class="card-surface rounded-2xl shadow-lg p-5 sm:p-6 border">
    <form action="/admin/empleados/<%= empleado.id %>/editar" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Nombre completo</label>
        <input type="text" name="nombre" value="<%= empleado.nombre %>" required
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Email</label>
        <input type="email" name="email" value="<%= empleado.email %>" required
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Contraseña <span class="font-normal text-xs opacity-60">(dejar vacío para no cambiar)</span></label>
        <input type="password" name="password"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Área / Carrera</label>
        <select name="area"
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
          <option value="">Sin área</option>
          <% areas.forEach(function(a) { %>
          <option value="<%= a._id %>" <%= empleado.area && empleado.area.toString() === a._id.toString() ? 'selected' : '' %>><%= a.nombre %></option>
          <% }); %>
        </select>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block text-xs font-semibold mb-1" style="color: var(--color-muted);">Hora inicio</label>
          <input type="time" name="hora_inicio" value="<%= empleado.hora_inicio || '' %>"
            class="w-full px-3 py-2 border-2 rounded-xl focus:ring-2 outline-none transition"
            style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
        </div>
        <div>
          <label class="block text-xs font-semibold mb-1" style="color: var(--color-muted);">Tolerancia</label>
          <input type="number" name="tolerancia_minutos" min="0" value="<%= empleado.toleranciaMinutos !== null && empleado.toleranciaMinutos !== undefined ? empleado.toleranciaMinutos : '' %>"
            class="w-full px-3 py-2 border-2 rounded-xl focus:ring-2 outline-none transition"
            style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
        </div>
        <div>
          <label class="block text-xs font-semibold mb-1" style="color: var(--color-muted);">Dto. x min</label>
          <input type="number" step="0.01" min="0" name="descuento_por_minuto" value="<%= empleado.descuentoPorMinuto !== null && empleado.descuentoPorMinuto !== undefined ? empleado.descuentoPorMinuto : '' %>"
            class="w-full px-3 py-2 border-2 rounded-xl focus:ring-2 outline-none transition"
            style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-4 border-t" style="border-color: var(--color-border);">
        <a href="/admin/empleados" class="px-5 py-2.5 border-2 rounded-xl text-sm font-medium transition"
          style="color: var(--color-muted); border-color: var(--color-border);">Cancelar</a>
        <button type="submit" class="btn-primary px-5 py-2.5 rounded-xl text-sm font-semibold shadow-lg transition">Guardar Cambios</button>
      </div>
    </form>
  </div>
</div>

<% titulo = 'Áreas - Admin'; %>
<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 mb-6">
  <h1 class="text-2xl sm:text-3xl font-bold text-primary">Áreas / Carreras</h1>
  <button onclick="document.getElementById('modalArea').classList.remove('hidden')"
    class="btn-primary px-5 py-2.5 rounded-xl text-sm font-semibold shadow-lg w-full sm:w-auto transition">
    + Nueva Área
  </button>
</div>

<div class="card-surface rounded-2xl shadow-lg overflow-hidden border">
  <div class="overflow-x-auto mobile-card-table">
    <table class="w-full text-sm">
      <thead style="background-color: var(--color-surface-alt);" class="text-muted uppercase text-xs">
        <tr>
          <th class="text-left py-3 px-3 sm:px-4">Nombre</th>
          <th class="text-left py-3 px-3 sm:px-4 hidden md:table-cell">Franjas disponibles</th>
          <th class="text-center py-3 px-3 sm:px-4">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% areas.forEach(function(a) { %>
        <tr>
          <td class="py-3 px-3 sm:px-4 font-semibold text-primary" data-label="Nombre"><%= a.nombre %></td>
          <td class="py-3 px-3 sm:px-4 text-muted text-xs hidden md:table-cell">
            <% var dias = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb']; %>
            <% for (var d = 0; d <= 6; d++) { %>
              <% var fs = a.franjasPorDia ? (a.franjasPorDia.get ? a.franjasPorDia.get(String(d)) : a.franjasPorDia[d]) : []; %>
              <% if (fs && fs.length > 0) { %>
                <span class="inline-block rounded-lg px-2 py-0.5 mr-1 mb-1" style="background-color: var(--color-surface-alt);"><%= dias[d] %>: <%= fs.join(', ') %></span>
              <% } %>
            <% } %>
          </td>
          <td class="text-center py-3 px-3 sm:px-4" data-label="Acciones">
            <div class="flex justify-center gap-1 sm:gap-2">
              <a href="/admin/areas/<%= a._id %>/editar" class="text-primary px-2.5 py-1 rounded-lg text-xs font-semibold transition hover:opacity-80" style="background-color: var(--color-primary-light);">Editar</a>
              <form action="/admin/areas/<%= a._id %>/delete" method="POST" class="inline" onsubmit="return confirm('¿Eliminar esta área?')">
                <button type="submit" class="text-red-600 bg-red-50 hover:bg-red-100 px-2.5 py-1 rounded-lg text-xs font-semibold transition">Eliminar</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
        <% if (areas.length === 0) { %>
        <tr><td colspan="3" class="text-center py-10 text-muted">No hay áreas registradas</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div id="modalArea" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4">
  <div class="card-surface rounded-2xl shadow-2xl w-full max-w-md p-5 border">
    <h2 class="text-lg font-bold text-primary mb-4">Nueva Área</h2>
    <form action="/admin/areas" method="POST" class="space-y-4">
      <div>
        <label class="block text-sm font-semibold mb-1.5" style="color: var(--color-muted);">Nombre del área o carrera</label>
        <input type="text" name="nombre" required
          class="w-full px-4 py-2.5 border-2 rounded-xl focus:ring-2 outline-none transition"
          style="border-color: var(--color-border); --tw-ring-color: var(--color-primary); background-color: var(--color-surface-alt); color: var(--color-muted);">
      </div>
      <p class="text-xs text-muted opacity-60">Después de crear el área, podrás configurar las franjas horarias.</p>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('modalArea').classList.add('hidden')"
          class="px-5 py-2.5 border-2 rounded-xl text-sm font-medium transition"
          style="color: var(--color-muted); border-color: var(--color-border);">Cancelar</button>
        <button type="submit" class="btn-primary px-5 py-2.5 rounded-xl text-sm font-semibold shadow-lg transition">Crear</button>
      </div>
    </form>
  </div>
</div>

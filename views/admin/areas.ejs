<% titulo = 'Áreas - Admin'; %>
<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-800">Áreas / Carreras</h1>
  <button onclick="document.getElementById('modalArea').classList.remove('hidden')"
    class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium">
    + Nueva Área
  </button>
</div>

<div class="bg-white rounded-xl shadow-md overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
      <tr>
        <th class="text-left py-3 px-4">Nombre</th>
        <th class="text-left py-3 px-4">Franjas disponibles</th>
        <th class="text-center py-3 px-4">Acciones</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% areas.forEach(function(a) { %>
      <tr class="hover:bg-gray-50">
        <td class="py-3 px-4 font-medium text-gray-800"><%= a.nombre %></td>
        <td class="py-3 px-4 text-gray-600 text-xs">
          <% var dias = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb']; %>
          <% for (var d = 0; d <= 6; d++) { %>
            <% var fs = a.franjasPorDia ? (a.franjasPorDia.get ? a.franjasPorDia.get(String(d)) : a.franjasPorDia[d]) : []; %>
            <% if (fs && fs.length > 0) { %>
              <span class="inline-block bg-gray-100 rounded px-1.5 py-0.5 mr-1 mb-1"><%= dias[d] %>: <%= fs.join(', ') %></span>
            <% } %>
          <% } %>
        </td>
        <td class="text-center py-3 px-4">
          <a href="/admin/areas/<%= a._id %>/editar" class="text-blue-600 hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-3 py-1 rounded text-xs font-medium">Editar</a>
          <form action="/admin/areas/<%= a._id %>/delete" method="POST" class="inline" onsubmit="return confirm('¿Eliminar esta área?')">
            <button type="submit" class="text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-3 py-1 rounded text-xs font-medium ml-1">Eliminar</button>
          </form>
        </td>
      </tr>
      <% }) %>
      <% if (areas.length === 0) { %>
      <tr><td colspan="3" class="text-center py-8 text-gray-500">No hay áreas registradas</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<div id="modalArea" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
    <h2 class="text-lg font-bold text-gray-800 mb-4">Nueva Área</h2>
    <form action="/admin/areas" method="POST" class="space-y-4">
      <div>
        <label class="block text-gray-700 text-sm font-medium mb-1">Nombre del área o carrera</label>
        <input type="text" name="nombre" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
      </div>
      <p class="text-xs text-gray-400">Después de crear el área, podrás configurar las franjas horarias por día.</p>
      <div class="flex justify-end space-x-3 pt-2">
        <button type="button" onclick="document.getElementById('modalArea').classList.add('hidden')"
          class="px-4 py-2 text-gray-600 border border-gray-300 rounded-lg text-sm">Cancelar</button>
        <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium">Crear</button>
      </div>
    </form>
  </div>
</div>

<% titulo = 'Tardanzas - Admin'; %>
<h1 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Tardanzas</h1>

<div class="bg-white dark:bg-gray-900 rounded-2xl p-4 mb-4 border border-gray-100 dark:border-gray-800 shadow-sm">
  <form method="GET" class="grid grid-cols-2 sm:grid-cols-4 gap-2 items-end">
    <div>
      <label class="block text-gray-400 text-[11px] font-semibold mb-1 uppercase">Desde</label>
      <input type="date" name="fecha_desde" value="<%= filtros.fecha_desde || '' %>" class="w-full px-2.5 py-2 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
    </div>
    <div>
      <label class="block text-gray-400 text-[11px] font-semibold mb-1 uppercase">Hasta</label>
      <input type="date" name="fecha_hasta" value="<%= filtros.fecha_hasta || '' %>" class="w-full px-2.5 py-2 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
    </div>
    <div>
      <label class="block text-gray-400 text-[11px] font-semibold mb-1 uppercase">Empleado</label>
      <select name="empleado_id" class="w-full px-2.5 py-2 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-xs focus:ring-2 focus:ring-blue-500 outline-none">
        <option value="">Todos</option>
        <% empleados.forEach(function(emp) { %>
        <option value="<%= emp.id %>" <%= filtros.empleado_id == emp.id ? 'selected' : '' %>><%= emp.nombre %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white px-3 py-2 rounded-xl text-xs font-semibold transition">Filtrar</button>
    </div>
  </form>
</div>

<% if (registros.length > 0) { %>
  <% var totalDescuento = 0; registros.forEach(function(r) { totalDescuento += Math.max(0, parseFloat(r.descuento_total || 0)); }); %>
  <div class="bg-white dark:bg-gray-900 rounded-2xl p-3 mb-4 border border-gray-100 dark:border-gray-800 shadow-sm flex justify-between items-center">
    <span class="text-gray-500 text-sm">📋 <strong><%= registros.length %></strong> registros</span>
    <span class="text-base font-bold text-red-600 dark:text-red-400">S/ <%= totalDescuento.toFixed(2) %></span>
  </div>

  <% semanas.forEach(function(semana) { %>
  <div class="mb-5">
    <div class="flex items-center gap-2.5 mb-2.5">
      <div class="w-8 h-8 bg-blue-100 dark:bg-blue-900 rounded-lg flex items-center justify-center text-blue-600 dark:text-blue-400 text-sm">📅</div>
      <div>
        <h2 class="font-bold text-gray-800 dark:text-white text-sm"><%= semana.label %></h2>
        <p class="text-[11px] text-gray-400"><%= semana.registros.length %> registros<% if (semana.totalTardanzas > 0) { %> · <span class="text-amber-500"><%= semana.totalTardanzas %> tard.</span><% } %> · <span class="text-red-500">S/ <%= semana.totalDescuento.toFixed(2) %></span></p>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 shadow-sm overflow-hidden">
      <div class="mobile-card-table">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 dark:bg-gray-800 text-gray-400 uppercase text-[11px]">
            <tr>
              <th class="text-left py-2.5 px-3">Empleado</th>
              <th class="text-center py-2.5 px-3">Día</th>
              <th class="text-center py-2.5 px-3 hidden sm:table-cell">Esperada</th>
              <th class="text-center py-2.5 px-3">Marcada</th>
              <th class="text-center py-2.5 px-3">Retraso</th>
              <th class="text-center py-2.5 px-3">Descuento</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <% semana.registros.forEach(function(r) { %>
            <tr>
              <td class="py-2.5 px-3" data-label="Empleado">
                <div class="font-semibold text-gray-800 dark:text-white text-xs"><%= r.empleado_nombre %></div>
                <div class="text-[11px] text-gray-400 sm:hidden"><%= r.fecha %></div>
              </td>
              <td class="text-center py-2.5 px-3" data-label="Día">
                <div class="font-medium text-gray-600 dark:text-gray-300 text-xs"><%= r.diaLabel %></div>
              </td>
              <td class="text-center py-2.5 px-3 text-gray-400 text-xs hidden sm:table-cell"><%= r.hora_esperada %></td>
              <td class="text-center py-2.5 px-3 font-mono font-bold text-xs <%= r.minutos_retraso > 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>" data-label="Marcada">
                <%= r.hora_marcacion.substring(0,5) %>
              </td>
              <td class="text-center py-2.5 px-3" data-label="Retraso">
                <% if (r.minutos_retraso > 0) { %>
                  <span class="bg-red-100 dark:bg-red-950 text-red-700 dark:text-red-300 px-2 py-0.5 rounded-full text-[11px] font-bold"><%= r.minutos_retraso %> min</span>
                <% } else { %>
                  <span class="bg-green-100 dark:bg-green-950 text-green-700 dark:text-green-300 px-2 py-0.5 rounded-full text-[11px] font-bold">OK</span>
                <% } %>
              </td>
              <td class="text-center py-2.5 px-3 font-bold text-xs <%= r.minutos_retraso > 0 ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>" data-label="Descuento">
                S/ <%= Math.max(0, parseFloat(r.descuento_total || 0)).toFixed(2) %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <% }) %>
<% } else { %>
<div class="bg-white dark:bg-gray-900 rounded-2xl border border-gray-100 dark:border-gray-800 p-8 text-center">
  <div class="w-14 h-14 mx-auto mb-3 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center text-2xl">📋</div>
  <p class="text-gray-400 text-sm">Sin registros</p>
</div>
<% } %>

<% if (totalPaginas > 1) { %>
<div class="flex justify-center mt-5 gap-1.5">
  <% var baseUrl = '/admin/tardanzas?'; if (filtros.fecha_desde) baseUrl += 'fecha_desde=' + filtros.fecha_desde + '&'; if (filtros.fecha_hasta) baseUrl += 'fecha_hasta=' + filtros.fecha_hasta + '&'; if (filtros.empleado_id) baseUrl += 'empleado_id=' + filtros.empleado_id + '&'; %>
  <% if (page > 1) { %>
    <a href="<%= baseUrl %>page=<%= page - 1 %>" class="px-3 py-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl text-xs font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition">← Ant</a>
  <% } %>
  <% for (var i = 1; i <= totalPaginas; i++) { %>
    <a href="<%= baseUrl %>page=<%= i %>" class="w-9 h-9 flex items-center justify-center rounded-xl text-xs font-medium transition <%= i === page ? 'bg-blue-600 text-white shadow-md' : 'bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800' %>"><%= i %></a>
  <% } %>
  <% if (page < totalPaginas) { %>
    <a href="<%= baseUrl %>page=<%= page + 1 %>" class="px-3 py-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-xl text-xs font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition">Sig →</a>
  <% } %>
</div>
<% } %>

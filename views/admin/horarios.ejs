<% titulo = 'Horarios - Admin'; %>
<h1 class="text-xl font-bold text-gray-800 dark:text-white mb-4">Gestión de Horarios</h1>

<div class="bg-white dark:bg-gray-900 rounded-2xl p-4 mb-4 border border-gray-100 dark:border-gray-800 shadow-sm">
  <form method="GET" class="flex gap-2">
    <select name="empleado_id" onchange="this.form.submit()" class="flex-1 px-3 py-2.5 border border-gray-300 dark:border-gray-700 dark:bg-gray-800 dark:text-white rounded-xl text-sm focus:ring-2 focus:ring-blue-500 outline-none">
      <option value="">-- Seleccionar docente --</option>
      <% empleados.forEach(function(emp) { %>
      <option value="<%= emp._id %>" <%= empleadoId == emp._id ? 'selected' : '' %>><%= emp.nombre %> <% if (emp.area) { %>(<%= emp.area.nombre %>)<% } %></option>
      <% }); %>
    </select>
    <% if (empleadoId) { %>
    <a href="/admin/horarios" class="px-3 py-2.5 text-gray-500 border border-gray-300 dark:border-gray-700 rounded-xl text-sm">Limpiar</a>
    <% } %>
  </form>
</div>

<% if (empleadoSeleccionado) { %>
<div class="bg-white dark:bg-gray-900 rounded-2xl p-4 border border-gray-100 dark:border-gray-800 shadow-sm">
  <div class="mb-3">
    <h2 class="text-sm font-bold text-gray-800 dark:text-white">
      <%= empleadoSeleccionado.nombre %>
      <% if (empleadoSeleccionado.area) { %>
        <span class="font-normal text-gray-400"> — <%= empleadoSeleccionado.area.nombre %></span>
      <% } %>
    </h2>
  </div>
  <form action="/admin/horarios" method="POST">
    <input type="hidden" name="empleado_id" value="<%= empleadoId %>">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 dark:bg-gray-800 text-gray-400 uppercase text-[11px]">
          <tr>
            <th class="text-left py-2 px-2">Día</th>
            <% if (empleadoSeleccionado.area) { %>
              <% var areaFranjas = empleadoSeleccionado.area.franjasPorDia; %>
              <% var todasFranjas = []; %>
              <% for (var d = 0; d <= 6; d++) { %>
                <% var fs = areaFranjas ? (areaFranjas.get ? areaFranjas.get(String(d)) : areaFranjas[d]) : []; %>
                <% fs.forEach(function(f) { if (!todasFranjas.includes(f)) todasFranjas.push(f); }); %>
              <% } %>
              <% todasFranjas.sort(); %>
              <% todasFranjas.forEach(function(f) { %>
                <th class="text-center py-2 px-1 text-[11px]"><%= f %></th>
              <% }); %>
            <% } else { %>
              <th class="text-center py-2">Sin área</th>
            <% } %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          <% for (var d = 0; d <= 6; d++) { %>
          <tr>
            <td class="py-2 px-2 font-semibold text-gray-800 dark:text-white text-xs"><%= dias[d] %></td>
            <% if (empleadoSeleccionado.area) { %>
              <% var areaFranjas = empleadoSeleccionado.area.franjasPorDia; %>
              <% var franjasDia = areaFranjas ? (areaFranjas.get ? areaFranjas.get(String(d)) : areaFranjas[d]) : []; %>
              <% var hDoc = horarioDocs.find(function(h) { return h.diaSemana === d; }); %>
              <% var franjasDoc = hDoc ? hDoc.franjas || [] : []; %>
              <% todasFranjas.forEach(function(f) { %>
                <% if (franjasDia.includes(f)) { %>
                  <td class="text-center py-2 px-1">
                    <input type="checkbox" name="franjas[<%= d %>]" value="<%= f %>" <%= franjasDoc.includes(f) ? 'checked' : '' %>
                      class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 cursor-pointer">
                  </td>
                <% } else { %>
                  <td class="text-center py-2 px-1 text-gray-300 dark:text-gray-600 text-xs">—</td>
                <% } %>
              <% }); %>
            <% } else { %>
              <td class="text-center py-2 text-gray-400 text-xs">Sin área</td>
            <% } %>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    <div class="flex justify-end mt-4">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2 rounded-xl text-sm transition w-full sm:w-auto">
        Guardar Horarios
      </button>
    </div>
  </form>
</div>
<% } %>

<% titulo = 'Horarios - Admin'; %>
<h1 class="text-2xl font-bold text-gray-800 mb-6">Gestión de Horarios</h1>

<div class="bg-white rounded-xl shadow-md p-6 mb-6">
  <form method="GET" class="flex items-end space-x-4">
    <div class="flex-1">
      <label class="block text-gray-700 text-sm font-medium mb-1">Seleccionar docente</label>
      <select name="empleado_id" onchange="this.form.submit()"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none">
        <option value="">-- Selecciona un docente --</option>
        <% empleados.forEach(function(emp) { %>
        <option value="<%= emp._id %>" <%= empleadoId == emp._id ? 'selected' : '' %>><%= emp.nombre %> <% if (emp.area) { %>(<%= emp.area.nombre %>)<% } %></option>
        <% }); %>
      </select>
    </div>
    <% if (empleadoId) { %>
    <a href="/admin/horarios" class="px-4 py-2 text-gray-600 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">Limpiar</a>
    <% } %>
  </form>
</div>

<% if (empleadoSeleccionado) { %>
<div class="bg-white rounded-xl shadow-md p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-gray-800">
      <%= empleadoSeleccionado.nombre %>
      <% if (empleadoSeleccionado.area) { %>
        <span class="text-sm font-normal text-gray-500">— <%= empleadoSeleccionado.area.nombre %></span>
      <% } %>
    </h2>
  </div>

  <form action="/admin/horarios" method="POST">
    <input type="hidden" name="empleado_id" value="<%= empleadoId %>">

    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
          <tr>
            <th class="text-left py-3 px-4">Día</th>
            <% if (empleadoSeleccionado.area) { %>
              <% var areaFranjas = empleadoSeleccionado.area.franjasPorDia; %>
              <% var todasFranjas = []; %>
              <% for (var d = 0; d <= 6; d++) { %>
                <% var fs = areaFranjas ? (areaFranjas.get ? areaFranjas.get(String(d)) : areaFranjas[d]) : []; %>
                <% fs.forEach(function(f) { if (!todasFranjas.includes(f)) todasFranjas.push(f); }); %>
              <% } %>
              <% todasFranjas.sort(); %>
              <% todasFranjas.forEach(function(f) { %>
                <th class="text-center py-3 px-3 text-xs"><%= f %></th>
              <% }); %>
            <% } else { %>
              <th class="text-center py-3 px-4">Sin área asignada</th>
            <% } %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% for (var d = 0; d <= 6; d++) { %>
          <tr class="hover:bg-gray-50">
            <td class="py-3 px-4 font-medium text-gray-800"><%= dias[d] %></td>
            <% if (empleadoSeleccionado.area) { %>
              <% var areaFranjas = empleadoSeleccionado.area.franjasPorDia; %>
              <% var franjasDia = areaFranjas ? (areaFranjas.get ? areaFranjas.get(String(d)) : areaFranjas[d]) : []; %>
              <% var hDoc = horarioDocs.find(function(h) { return h.diaSemana === d; }); %>
              <% var franjasDoc = hDoc ? hDoc.franjas || [] : []; %>
              <% todasFranjas.forEach(function(f) { %>
                <% if (franjasDia.includes(f)) { %>
                  <td class="text-center py-3 px-3">
                    <input type="checkbox" name="franjas[<%= d %>]" value="<%= f %>"
                      <%= franjasDoc.includes(f) ? 'checked' : '' %>
                      class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500">
                  </td>
                <% } else { %>
                  <td class="text-center py-3 px-3 text-gray-300 text-xs">—</td>
                <% } %>
              <% }); %>
            <% } else { %>
              <td class="text-center py-3 px-4 text-gray-400 text-xs">Asigna un área al docente primero</td>
            <% } %>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="flex justify-end mt-6">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2.5 rounded-lg text-sm">
        Guardar Horarios
      </button>
    </div>
  </form>
</div>
<% } %>

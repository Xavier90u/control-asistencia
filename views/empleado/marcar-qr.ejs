<% titulo = 'Marcar por QR'; %>
<div class="max-w-md mx-auto">
  <div class="text-center mb-5">
    <h1 class="text-xl font-bold text-gray-800 dark:text-white">Marcar Asistencia</h1>
    <p class="text-gray-500 dark:text-gray-400 text-sm mt-1"><%= empleado.nombre %></p>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-2xl p-5 border border-gray-100 dark:border-gray-800 shadow-sm">
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-300 p-3 rounded-xl mb-4 text-sm text-center">
      ⚠️ <%= error %>
    </div>
    <% } %>

    <% if (todosMarcados) { %>
      <div class="text-center py-4">
        <div class="w-16 h-16 mx-auto mb-3 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center text-3xl">✅</div>
        <h2 class="text-lg font-bold text-green-600 dark:text-green-400 mb-2">Todos los turnos registrados</h2>
        <p class="text-gray-400 dark:text-gray-500 text-xs">Ya marcaste todos tus turnos hoy.</p>
      </div>
    <% } else { %>
      <div class="space-y-2.5">
        <% franjas.forEach(function(f) { %>
          <% if (f.marcada) { %>
            <div class="bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 rounded-xl p-3.5 flex justify-between items-center">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center text-green-600 text-sm">✓</div>
                <span class="font-bold text-gray-800 dark:text-white text-sm"><%= f.franja %></span>
              </div>
              <span class="text-green-600 font-bold text-xs bg-green-100 dark:bg-green-900 px-2.5 py-0.5 rounded-full">OK</span>
            </div>
          <% } else if (f.disponible) { %>
            <form action="/empleado/marcar-qr" method="POST">
              <input type="hidden" name="token" value="<%= token %>">
              <input type="hidden" name="franja" value="<%= f.franja %>">
              <button type="submit" class="w-full bg-blue-50 dark:bg-blue-950 border border-blue-200 dark:border-blue-800 rounded-xl p-3.5 flex justify-between items-center hover:bg-blue-100 dark:hover:bg-blue-900 transition cursor-pointer text-left">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center text-blue-600 text-sm">🕐</div>
                  <div>
                    <span class="font-bold text-gray-800 dark:text-white text-sm"><%= f.franja %></span>
                    <p class="text-blue-600 dark:text-blue-400 text-[11px]">Toca para marcar</p>
                  </div>
                </div>
                <span class="bg-blue-600 text-white px-3 py-1.5 rounded-xl text-xs font-bold">MARCAR</span>
              </button>
            </form>
          <% } else { %>
            <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-3.5 flex justify-between items-center opacity-50">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center text-gray-400 text-sm">🔒</div>
                <span class="font-bold text-gray-500 dark:text-gray-400 text-sm"><%= f.franja %></span>
              </div>
              <span class="text-gray-400 text-[11px] bg-gray-200 dark:bg-gray-700 px-2.5 py-0.5 rounded-full">Bloqueado</span>
            </div>
          <% } %>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

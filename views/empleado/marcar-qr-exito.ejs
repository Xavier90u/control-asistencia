<% titulo = 'Marcado Exitoso'; %>
<div class="max-w-md mx-auto">
  <div class="text-center mb-5">
    <h1 class="text-xl font-bold text-gray-800 dark:text-white">Asistencia Registrada</h1>
  </div>

  <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 border border-gray-100 dark:border-gray-800 shadow-sm text-center">
    <% if (minutosRetraso > 0) { %>
      <div class="w-16 h-16 mx-auto mb-3 bg-amber-100 dark:bg-amber-900 rounded-full flex items-center justify-center text-3xl">⚠️</div>
      <h2 class="text-lg font-bold text-amber-600 dark:text-amber-400 mb-1"><%= resultMsg %></h2>
      <p class="text-gray-500 dark:text-gray-400 text-sm">Franja: <strong><%= franja %></strong></p>
    <% } else { %>
      <div class="w-16 h-16 mx-auto mb-3 bg-green-100 dark:bg-green-900 rounded-full flex items-center justify-center text-3xl">✅</div>
      <h2 class="text-lg font-bold text-green-600 dark:text-green-400 mb-1"><%= resultMsg %></h2>
      <p class="text-gray-500 dark:text-gray-400 text-sm">Franja: <strong><%= franja %></strong></p>
    <% } %>

    <div class="mt-6">
      <p class="text-xs text-gray-400 dark:text-gray-500 mb-3"><%= empleado.nombre %></p>
      <a href="/" class="bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 py-2.5 px-6 rounded-xl text-sm font-medium transition hover:bg-gray-200 dark:hover:bg-gray-700 inline-block">
        Cerrar
      </a>
    </div>
  </div>
</div>

<% titulo = 'Marcar Entrada'; %>
<div class="max-w-lg mx-auto">
  <div class="text-center mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-primary">Marcar Entrada</h1>
    <p class="text-muted text-sm mt-1">Bienvenido, <%= user.nombre %></p>
  </div>

  <div class="card-surface rounded-2xl shadow-xl p-5 sm:p-6 border">
    <% if (todosMarcados) { %>
      <div class="text-center py-4">
        <div class="w-20 h-20 mx-auto mb-4 bg-green-100 rounded-full flex items-center justify-center text-4xl">✅</div>
        <h2 class="text-xl font-bold text-green-600 mb-4">Todos los turnos registrados</h2>
        <% franjas.forEach(function(f) { %>
          <div class="bg-green-50 border border-green-200 rounded-xl p-3 mb-2 text-left flex justify-between items-center">
            <span class="font-semibold text-primary"><%= f.franja %></span>
            <span class="text-green-600 text-sm font-medium">✅ Marcado</span>
          </div>
        <% }); %>
        <p class="text-muted text-sm mt-5">Completaste todos tus turnos hoy. Vuelve mañana.</p>
      </div>
    <% } else if (franjas.length === 0) { %>
      <div class="text-center py-10">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center text-3xl" style="background-color: var(--color-primary-light);">📅</div>
        <p class="text-muted font-medium">No tienes turnos asignados para hoy</p>
        <p class="text-muted text-sm mt-2 opacity-60">Consulta con el administrador</p>
      </div>
    <% } else { %>
      <div class="text-center mb-6">
        <div class="text-4xl sm:text-5xl font-bold text-primary mb-1 font-mono tracking-wider" id="reloj"></div>
        <p class="text-muted text-sm" id="fecha"></p>
      </div>

      <div class="space-y-3 mb-6">
        <% franjas.forEach(function(f) { %>
          <% if (f.marcada) { %>
            <div class="bg-green-50 border-2 border-green-200 rounded-xl p-4 flex justify-between items-center">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center text-green-600 text-lg">✓</div>
                <div>
                  <span class="font-bold text-primary text-lg"><%= f.franja %></span>
                  <p class="text-green-600 text-xs">Turno completado</p>
                </div>
              </div>
              <span class="text-green-600 font-semibold text-sm bg-green-100 px-3 py-1 rounded-full">OK</span>
            </div>
          <% } else if (f.disponible) { %>
            <div class="border-2 rounded-xl p-4 flex justify-between items-center" style="background-color: var(--color-primary-light); border-color: var(--color-primary);">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg" style="background-color: var(--color-primary); color: #fff;">🕐</div>
                <div>
                  <span class="font-bold text-primary text-lg"><%= f.franja %></span>
                  <p class="text-primary text-xs">Listo para marcar</p>
                </div>
              </div>
              <form action="/empleado/marcar" method="POST" class="inline">
                <input type="hidden" name="franja" value="<%= f.franja %>">
                <button type="submit" class="btn-primary px-5 py-2.5 rounded-xl text-sm font-bold shadow-lg transition">
                  MARCAR
                </button>
              </form>
            </div>
          <% } else { %>
            <div class="card-surface border-2 rounded-xl p-4 flex justify-between items-center opacity-50" style="border-color: var(--color-border);">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-lg" style="background-color: var(--color-surface-alt); color: var(--color-muted);">🔒</div>
                <div>
                  <span class="font-bold text-primary text-lg opacity-60"><%= f.franja %></span>
                  <p class="text-muted text-xs">Disponible desde <strong><%= (() => {
                    var partes = f.franja.split(':');
                    var h = parseInt(partes[0]);
                    var m = parseInt(partes[1]) - 10;
                    if (m < 0) { h--; m += 60; }
                    return String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0');
                  })() %></strong></p>
                </div>
              </div>
              <span class="text-muted text-xs px-3 py-1 rounded-full" style="background-color: var(--color-surface-alt);">Bloqueado</span>
            </div>
          <% } %>
        <% }); %>
      </div>

      <% if (typeof retraso !== 'undefined' && retraso) { %>
      <div class="bg-amber-50 border border-amber-200 text-amber-700 p-4 rounded-xl mb-4 text-sm text-center flex items-center justify-center gap-2">
        <span>⚠️</span> Registraste con <strong><%= retraso %> min</strong> de retraso
      </div>
      <% } %>
    <% } %>

    <div class="mt-6 text-center border-t pt-4" style="border-color: var(--color-border);">
      <a href="/empleado/historial" class="text-primary text-sm font-medium">📋 Ver mi historial →</a>
    </div>
  </div>
</div>

<script>
function actualizarReloj() {
  const ahora = new Date();
  const h = String(ahora.getHours()).padStart(2, '0');
  const m = String(ahora.getMinutes()).padStart(2, '0');
  const s = String(ahora.getSeconds()).padStart(2, '0');
  const el = document.getElementById('reloj');
  if (el) el.textContent = h + ':' + m + ':' + s;
  const fechaEl = document.getElementById('fecha');
  if (fechaEl) {
    const opciones = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    fechaEl.textContent = ahora.toLocaleDateString('es-PE', opciones);
  }
}
actualizarReloj();
setInterval(actualizarReloj, 1000);
</script>

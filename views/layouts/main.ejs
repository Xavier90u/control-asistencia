<!DOCTYPE html>
<html lang="es" class="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof titulo !== 'undefined' ? titulo : 'Control de Asistencia' %></title>
  <link rel="stylesheet" href="/css/output.css?v=<%= CSS_VERSION %>">
  <script>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <style>
    .toggle{position:relative;width:52px;height:28px;border-radius:14px;cursor:pointer;background:#e2e8f0;transition:background .3s}
    .dark .toggle{background:#334155}
    .toggle .knob{position:absolute;top:2px;left:2px;width:24px;height:24px;border-radius:50%;background:#fbbf24;transition:transform .3s,background .3s;display:flex;align-items:center;justify-content:center;font-size:13px}
    .toggle.on .knob{transform:translateX(24px);background:#818cf8}
    .notif-badge{position:absolute;top:-4px;right:-4px;min-width:18px;height:18px;background:#ef4444;color:#fff;border-radius:9px;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 4px;border:2px solid #fff}
    .dark .notif-badge{border-color:#111827}
    .notif-panel{position:absolute;right:0;top:100%;margin-top:8px;width:340px;max-height:400px;overflow-y:auto;background:#fff;border:1px solid #e5e7eb;border-radius:16px;box-shadow:0 20px 40px rgba(0,0,0,.12);z-index:50;display:none}
    .dark .notif-panel{background:#111827;border-color:#1f2937}
    .notif-panel.show{display:block}
  </style>
</head>
<body class="bg-gray-50 dark:bg-gray-950 min-h-screen transition-colors duration-300">
  <% if (user) { %>
  <nav class="bg-white dark:bg-gray-900 shadow-sm sticky top-0 z-40 border-b border-gray-200 dark:border-gray-800">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex items-center justify-between h-14">
        <a href="/" class="font-bold text-base flex items-center gap-2 text-gray-800 dark:text-white">
          <span class="text-lg">⏰</span> <span class="hidden sm:inline">Control Asistencia</span>
        </a>

        <div class="hidden md:flex items-center gap-1">
          <% if (user.rol === 'admin') { %>
            <a href="/admin" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Dashboard</a>
            <a href="/admin/empleados" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Empleados</a>
            <a href="/admin/areas" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Áreas</a>
            <a href="/admin/horarios" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Horarios</a>
            <a href="/admin/tardanzas" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Tardanzas</a>
            <a href="/admin/config" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Config</a>
          <% } else { %>
            <a href="/empleado" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Marcar</a>
            <a href="/empleado/historial" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Historial</a>
            <a href="/empleado/qr" class="px-3 py-1.5 rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition">Mi QR</a>
          <% } %>
        </div>

        <div class="flex items-center gap-2">
          <% if (user.rol === 'admin') { %>
          <div class="relative">
            <button onclick="toggleNotifPanel()" class="relative p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition">
              <svg class="w-5 h-5 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
              <span id="notifBadge" class="notif-badge hidden"><%= typeof noLeidas !== 'undefined' ? noLeidas : 0 %></span>
            </button>
            <div id="notifPanel" class="notif-panel">
              <div class="p-3 border-b border-gray-100 dark:border-gray-800 flex justify-between items-center">
                <span class="text-sm font-bold text-gray-800 dark:text-white">Notificaciones</span>
                <button onclick="marcarLeidas()" class="text-[11px] text-blue-600 dark:text-blue-400 hover:underline">Marcar todo leído</button>
              </div>
              <div id="notifList" class="divide-y divide-gray-100 dark:divide-gray-800">
                <% if (typeof notificaciones !== 'undefined') { %>
                  <% notificaciones.forEach(function(n) { %>
                  <div class="px-3 py-2.5 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition">
                    <p class="text-xs text-gray-700 dark:text-gray-200"><%= n.mensaje %></p>
                    <p class="text-[11px] text-gray-400 dark:text-gray-500 mt-0.5"><%= n.hora %> · <%= n.fecha %></p>
                  </div>
                  <% }); %>
                <% } %>
                <div id="notifEmpty" class="hidden p-6 text-center text-gray-400 text-sm">Sin notificaciones</div>
              </div>
            </div>
          </div>
          <% } %>

          <div class="flex items-center gap-2 ml-2 pl-2 border-l border-gray-200 dark:border-gray-700">
            <span class="text-xs text-gray-500 dark:text-gray-400 hidden sm:inline"><%= user.nombre %></span>
            <a href="/logout" class="inline-flex items-center gap-1 px-3 py-1.5 bg-red-500 hover:bg-red-600 text-white rounded-lg text-xs font-semibold transition shadow-sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              Salir
            </a>
          </div>
          <div class="toggle" id="themeToggle" onclick="toggleTheme()" title="Modo día/noche">
            <div class="knob"><span id="themeIcon">☀️</span></div>
          </div>
          <button onclick="document.getElementById('mob').classList.toggle('hidden')" class="md:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition">
            <svg class="w-5 h-5 text-gray-600 dark:text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div id="mob" class="hidden md:hidden border-t border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
      <div class="px-4 py-2 space-y-1">
        <% if (user.rol === 'admin') { %>
          <a href="/admin" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>📊</span> Dashboard</a>
          <a href="/admin/empleados" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>👥</span> Empleados</a>
          <a href="/admin/areas" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>🏢</span> Áreas</a>
          <a href="/admin/horarios" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>🕐</span> Horarios</a>
          <a href="/admin/tardanzas" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>⚠️</span> Tardanzas</a>
          <a href="/admin/config" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>⚙️</span> Configuración</a>
        <% } else { %>
          <a href="/empleado" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>✅</span> Marcar Entrada</a>
          <a href="/empleado/historial" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>📋</span> Mi Historial</a>
          <a href="/empleado/qr" class="flex items-center gap-3 py-3 px-3 rounded-xl text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-800 transition"><span>📱</span> Mi QR</a>
        <% } %>
        <div class="border-t border-gray-200 dark:border-gray-800 pt-3 mt-2">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-gray-700 dark:text-gray-200 font-medium pl-3">👤 <%= user.nombre %></span>
            <span class="text-[11px] text-gray-400 dark:text-gray-500 px-3"><%= user.rol === 'admin' ? 'Administrador' : 'Empleado' %></span>
          </div>
          <a href="/logout" class="flex items-center gap-2 w-full py-3 px-3 bg-red-500 hover:bg-red-600 text-white rounded-xl text-sm font-semibold transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Cerrar Sesión
          </a>
        </div>
      </div>
    </div>
  </nav>
  <% } %>

  <main class="max-w-5xl mx-auto px-4 py-5">
    <% if (typeof success !== 'undefined' && success) { %>
    <div class="bg-green-50 dark:bg-green-950 border border-green-200 dark:border-green-800 text-green-700 dark:text-green-300 p-3 rounded-xl mb-4 text-sm flex justify-between items-center">
      <span><%= success %></span>
      <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-600 font-bold text-lg leading-none">&times;</button>
    </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 text-red-700 dark:text-red-300 p-3 rounded-xl mb-4 text-sm flex justify-between items-center">
      <span><%= error %></span>
      <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600 font-bold text-lg leading-none">&times;</button>
    </div>
    <% } %>
    <%- body %>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    var socket = io();

    <% if (user && user.rol === 'admin') { %>
    socket.emit('join-admin');
    socket.on('nueva-notificacion', function(data) {
      var badge = document.getElementById('notifBadge');
      if (badge) {
        badge.classList.remove('hidden');
        var count = parseInt(badge.textContent) || 0;
        badge.textContent = count + 1;
      }
      var list = document.getElementById('notifList');
      if (list) {
        var empty = document.getElementById('notifEmpty');
        if (empty) empty.classList.add('hidden');
        var div = document.createElement('div');
        div.className = 'px-3 py-2.5 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition';
        div.innerHTML = '<p class="text-xs text-gray-700 dark:text-gray-200">' + data.mensaje + '</p><p class="text-[11px] text-gray-400 dark:text-gray-500 mt-0.5">' + data.hora + ' · ' + data.fecha + '</p>';
        list.insertBefore(div, list.firstChild);
      }
      if (Notification && Notification.permission === 'granted') {
        new Notification('Control de Asistencia', { body: data.mensaje, icon: '/favicon.ico' });
      }
    });
    <% } %>

    <% if (user && user.rol === 'empleado') { %>
    socket.emit('join-empleado', '<%= user.id %>');
    <% } %>

    function toggleNotifPanel() {
      var panel = document.getElementById('notifPanel');
      panel.classList.toggle('show');
    }

    function marcarLeidas() {
      fetch('/admin/notificaciones/leer', { method: 'POST' });
      var badge = document.getElementById('notifBadge');
      if (badge) badge.classList.add('hidden');
    }

    document.addEventListener('click', function(e) {
      var panel = document.getElementById('notifPanel');
      var btn = e.target.closest('[onclick*="toggleNotifPanel"]');
      if (panel && !panel.contains(e.target) && !btn) {
        panel.classList.remove('show');
      }
    });

    function toggleTheme() {
      document.documentElement.classList.toggle('dark');
      var isDark = document.documentElement.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      document.getElementById('themeToggle').className = 'toggle' + (isDark ? ' on' : '');
      document.getElementById('themeIcon').textContent = isDark ? '🌙' : '☀️';
    }
    (function() {
      var d = document.documentElement.classList.contains('dark');
      var t = document.getElementById('themeToggle');
      var i = document.getElementById('themeIcon');
      if (t) { t.className = 'toggle' + (d ? ' on' : ''); i.textContent = d ? '🌙' : '☀️'; }
      var badge = document.getElementById('notifBadge');
      if (badge) {
        var count = parseInt(badge.textContent) || 0;
        if (count > 0) badge.classList.remove('hidden');
      }
      if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
      }
    })();
  </script>
</body>
</html>
